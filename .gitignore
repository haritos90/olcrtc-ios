# Xcode
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
*.xcworkspace/contents.xcworkspacedata
DerivedData/
.build/
*.ipa
*.dSYM.zip
*.dSYM

# macOS
.DS_Store
*.swp
*.orig

# Logs (generated at runtime, not source)
logs/

# Python (parity_check.py bytecode cache)
__pycache__/
*.pyc

# SPM
.swiftpm/

# Claude Code settings (local only)
.claude/

# xcodeproj generated by xcodegen — don't commit, regenerate with:
#   xcodegen generate --spec project.yml
olcrtc-ios.xcodeproj/

# gomobile binary — too large for plain git, use git-lfs or rebuild locally
App/Mobile.xcframework/
